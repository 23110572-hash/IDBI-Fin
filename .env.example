# ---------------------------------------------------------------------------
# IDBIFin — example environment. Copy to `.env` (git-ignored) and fill in.
# All backend vars use the MSME_ prefix. In production these are set on Render.
# ---------------------------------------------------------------------------

# --- Environment ---
MSME_ENVIRONMENT=development

# --- Persistence (required) ---
# Neon Postgres connection string. The app has no local fallback — this must be set.
MSME_DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>/<db>?sslmode=require

# --- ML artifacts ---
# The backend ships its own trained model in backend/model_artifacts. Override only to point
# at a different set of artifacts:
# MSME_ARTIFACT_DIR=/path/to/artifacts

# --- Auth (HS256 JWT) ---
# SECURITY: set a strong random secret (Render generates one automatically). Users live in the
# database and are created through the Sign Up flow — there are no built-in accounts.
MSME_JWT_SECRET=set-a-strong-random-secret
MSME_JWT_EXPIRY_MINUTES=60
MSME_AUTH_ENABLED=true

# --- Connectors ---
MSME_CONNECTOR_TIMEOUT_SECONDS=8

# --- Background jobs (Celery) ---
# Tasks run inline via an in-memory broker; no external queue is required. Leave as-is.
MSME_CELERY_TASK_ALWAYS_EAGER=true

# --- CORS (allowed frontend origins, comma-separated) ---
# Set to the deployed Vercel frontend URL.
MSME_CORS_ORIGINS=https://idbi-fin.vercel.app

# --- Frontend (Vite) ---
# The SPA calls this backend base URL directly (see frontend/src/lib/api.ts).
VITE_API_BASE=https://idbi-fin.onrender.com
