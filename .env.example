# ---------------------------------------------------------------------------
# MSME Financial Health Card — example environment.
# Copy to `.env` (git-ignored) and adjust. All backend vars use the MSME_ prefix.
# ---------------------------------------------------------------------------

# --- Environment ---
MSME_ENVIRONMENT=local

# --- Persistence ---
# Local standalone dev uses a SQLite file by default (leave unset). For Postgres:
# MSME_DATABASE_URL=postgresql+psycopg2://msme:msme_dev_pw@localhost:5432/msme
MSME_REDIS_URL=redis://localhost:6379/0

# --- ML artifacts (trained model location) ---
# Defaults to <repo>/ml/artifacts; override if artifacts live elsewhere.
# MSME_ARTIFACT_DIR=E:/IDBI/ml/artifacts

# --- Auth (JWT / local Cognito stand-in) ---
# SECURITY: set a strong secret in every non-local environment. If unset, an ephemeral
# per-process secret is generated (tokens won't survive a restart).
MSME_JWT_SECRET=change-me-in-non-local-environments
MSME_JWT_EXPIRY_MINUTES=60
MSME_AUTH_ENABLED=true

# Dev sign-in passwords (local Cognito stand-in). Override the defaults if you like.
# MSME_ADMIN_PASSWORD=admin123!
# MSME_OFFICER_PASSWORD=officer123!
# MSME_RM_PASSWORD=rm123!

# --- Celery (background + Mode-B jobs) ---
# Local dev runs tasks inline (eager). Set to false when a Redis broker + worker are up.
MSME_CELERY_TASK_ALWAYS_EAGER=true
MSME_CELERY_BROKER_URL=redis://localhost:6379/1
MSME_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Connectors ---
MSME_CONNECTOR_TIMEOUT_SECONDS=8

# --- OCR / S3 (stubbed locally) ---
MSME_USE_TEXTRACT=false
MSME_S3_BUCKET=msme-artifacts-local

# --- CORS (frontend origins) ---
MSME_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Frontend (Vite) ---
# Dev server proxies /api to this target:
VITE_API_TARGET=http://localhost:8000
